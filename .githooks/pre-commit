#!/bin/sh
# Pre-commit hook: prevent accidental commit of .env files with real credentials

if git rev-parse --verify HEAD >/dev/null 2>&1; then
    against=HEAD
else
    against=4b825dc642cb6eb9a060e54bf899d153036d1f7b
fi

staged_env=$(git diff --cached --name-only --diff-filter=A | grep -E '\.env$' || true)

if [ -n "$staged_env" ]; then
    echo "ERROR: Estas intentando committear archivos .env:"
    echo "$staged_env"
    echo "Los archivos .env contienen credenciales y no deben committearse."
    echo "Usa .env.example como template en su lugar."
    exit 1
fi
